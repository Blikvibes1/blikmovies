# Copy this file to .env.local and fill in real values.
# .env.local is already git-ignored, so your real keys never get committed.

NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# TMDB v4 "API Read Access Token" (Settings → API → API Read Access Token)
TMDB_API_KEY=your_tmdb_read_access_token

# Optional — only needed for the /admin "Sync from TMDB" button.
# Settings → API → service_role key. Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=
